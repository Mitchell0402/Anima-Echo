# Godot 4+ specific ignores
.godot/
.nomedia

# Local Codex/session files
.codex/session-start.md
.codex/environments/

# Local secrets
.env
.env.local

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# OpenCode / Godot MCP Pro nested install copy
# The real plugin lives at addons/godot_mcp/. OpenCode installs a duplicate
# at addons/godot_mcp/godot_mcp/ on first run; ignore that nested copy.
addons/godot_mcp/godot_mcp/

# Local OpenCode config (per-machine, not part of the project)
opencode.json
scripts/__pycache__/
