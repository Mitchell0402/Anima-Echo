; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mine Platform V2"
run/main_scene="res://scenes/ui/title_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

NoiseSystem="*res://scripts/core/noise_system.gd"
ItemDatabase="*res://scripts/items/item_database.gd"
GameRuntime="*res://scripts/core/game_runtime.gd"
WeightSystem="*res://scripts/core/weight_system.gd"
MCPScreenshot="*res://addons/godot_mcp/mcp_screenshot_service.gd"
MCPInputService="*res://addons/godot_mcp/mcp_input_service.gd"
MCPGameInspector="*res://addons/godot_mcp/mcp_game_inspector_service.gd"
StabilitySystem="*res://scripts/core/stability_system.gd"
DayNightCycle="*res://scripts/core/day_night_cycle.gd"
SfxSystem="*res://scripts/core/sfx_system.gd"

[display]

window/size/viewport_height=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"
#Pixel-perfectdisplaymode.Godotkeepstheinternalviewportat#1280x720(worldcoordinates)andletterbox-scalesthewindowtofit.#`viewport`mode+`keep`aspectratio+`integer`scalemodearethe#2D-pixel-gamestandard(StardewValley,Celeste,Undertalepattern).#TheactualzoomischosenbyGameCamera2Dinscripts/camera_2d.gd.window/size/viewport_width=1280
window/size/minimum_width=900
window/size/minimum_height=600

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

