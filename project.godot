; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mine Platform V2"
run/main_scene="uid://dxjbgwnb1j7cw"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

NoiseSystem="*res://scripts/core/noise_system.gd"
ItemDatabase="*res://scripts/items/item_database.gd"
GameRuntime="*res://scripts/core/game_runtime.gd"
WeightSystem="*res://scripts/core/weight_system.gd"
MCPScreenshot="*res://addons/godot_mcp/mcp_screenshot_service.gd"
MCPInputService="*res://addons/godot_mcp/mcp_input_service.gd"
MCPGameInspector="*res://addons/godot_mcp/mcp_game_inspector_service.gd"

[display]

# Pixel-perfect display mode. Godot keeps the internal viewport at
# 1280x720 (world coordinates) and letterbox-scales the window to fit.
# `viewport` mode + `keep` aspect ratio + `integer` scale mode are the
# 2D-pixel-game standard (Stardew Valley, Celeste, Undertale pattern).
# The actual zoom is chosen by GameCamera2D in scripts/camera_2d.gd.
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/minimum_width=900
window/size/minimum_height=600
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"

[autoload]

NoiseSystem="*res://scripts/core/noise_system.gd"
ItemDatabase="*res://scripts/items/item_database.gd"
GameRuntime="*res://scripts/core/game_runtime.gd"
WeightSystem="*res://scripts/core/weight_system.gd"
OxygenSystem="*res://scripts/core/oxygen_system.gd"
MCPScreenshot="*res://addons/godot_mcp/mcp_screenshot_service.gd"
MCPInputService="*res://addons/godot_mcp/mcp_input_service.gd"
MCPGameInspector="*res://addons/godot_mcp/mcp_game_inspector_service.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[input_devices]

pointing_emulation="off"

